# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ─── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/healthlete_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthlete_dev
DB_USER=postgres
DB_PASSWORD=password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=changeme_supersecret_at_least_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=changeme_refresh_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Redis (caching) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI / LLM ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Vendor Integrations ──────────────────────────────────
HYPEAUDITOR_API_KEY=
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
SPONSOR_UNITED_API_KEY=

# ─── AWS ──────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=healthlete-media

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://app.healthlete.com

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
